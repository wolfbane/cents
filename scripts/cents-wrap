#!/usr/bin/env bash
# Wrapper for cron / launchd dispatch.
#
# Purpose: give scheduled jobs a single entry point that fixes timezone,
# resolves the cents binary explicitly (no PATH lookup), substitutes a few
# deploy-time-dynamic args, and tees output to a per-day log directory.
#
# Deployed to ~/.cents/bin/cents-wrap on the Mac mini (see OPERATIONS.md).
# Edit CENTS_BIN below to match the venv location on the target machine.
#
# Usage:
#   cents-wrap <job-name> <cents arg> [<cents arg>...]
#
# Sentinel substitution (any arg that exactly matches a sentinel is replaced):
#   __DATE_SECONDS__   →  $(date +%s)        per-day reproducible seed
#   __DATE_ISO__       →  $(date +%Y-%m-%d)  today's date
#
# Example plist ProgramArguments for the random arm:
#   <string>$HOME/.cents/bin/cents-wrap</string>
#   <string>factory-random</string>
#   <string>factory</string>
#   <string>run</string>
#   <string>--orchestrator</string>
#   <string>random</string>
#   <string>--orchestrator-seed</string>
#   <string>__DATE_SECONDS__</string>
#   <string>--max-cost-usd</string>
#   <string>10</string>

set -euo pipefail

# Anchor schedules to US market hours regardless of machine timezone.
export TZ="America/New_York"

# Resolve cents explicitly. Adjust to wherever your editable install lives.
CENTS_BIN="${CENTS_BIN:-$HOME/.venvs/cents/bin/cents}"

if [[ ! -x "$CENTS_BIN" ]]; then
    echo "[cents-wrap] ERROR: $CENTS_BIN is not executable" >&2
    echo "[cents-wrap] Edit CENTS_BIN in this script (or export CENTS_BIN env var)" >&2
    exit 127
fi

# Per-day log directory under $HOME/.cents/logs/YYYY-MM-DD/.
LOG_DIR="$HOME/.cents/logs/$(date +%Y-%m-%d)"
mkdir -p "$LOG_DIR"

CMD_NAME="${1:?cents-wrap: first arg must be a job name}"; shift

# Sentinel substitution — plists can't run shell expansion, so we do it here.
ARGS=()
for arg in "$@"; do
    case "$arg" in
        __DATE_SECONDS__) ARGS+=("$(date +%s)") ;;
        __DATE_ISO__)     ARGS+=("$(date +%Y-%m-%d)") ;;
        *)                ARGS+=("$arg") ;;
    esac
done

LOG_FILE="$LOG_DIR/${CMD_NAME}.log"

{
    echo "[cents-wrap] $(date -Iseconds) start $CMD_NAME"
    echo "[cents-wrap] cmd: $CENTS_BIN ${ARGS[*]:-}"
} >>"$LOG_FILE"

# Network preflight for factory runs.
#
# Factory runs need both Alpaca (prices) and FMP (fundamentals/sector) to be
# reachable; a transient network outage during the launchd-fire window has
# produced zombie theses and SPY-fallback contamination in the past. For
# factory-* jobs, check both hosts with a short connect timeout and skip
# the run cleanly if either is unreachable. Exit 0 so launchd treats this
# as "deliberately skipped" rather than a crash.
#
# Other job types (eval, status, delistings, event-refresh) don't gate on
# this — eval is local, status is local, event-refresh has its own retry
# logic, and delistings is idempotent.
if [[ "$CMD_NAME" == factory-* ]]; then
    PREFLIGHT_FAILED=""
    for host in api.alpaca.markets financialmodelingprep.com; do
        if ! curl --connect-timeout 3 --max-time 5 -sS -o /dev/null "https://${host}/" 2>/dev/null; then
            echo "[cents-wrap] preflight FAILED: ${host} unreachable" >>"$LOG_FILE"
            PREFLIGHT_FAILED="$host"
        fi
    done
    if [[ -n "$PREFLIGHT_FAILED" ]]; then
        echo "[cents-wrap] $(date -Iseconds) SKIP $CMD_NAME — network preflight failed (${PREFLIGHT_FAILED})" >>"$LOG_FILE"
        exit 0
    fi
    echo "[cents-wrap] preflight OK (alpaca + fmp reachable)" >>"$LOG_FILE"
fi

# Exec cents — output appended to the per-day log. Exit code propagates to launchd.
# ${ARGS[@]+"${ARGS[@]}"} is the bash-3.2-safe form for an empty array under
# `set -u`. macOS ships bash 3.2 as /bin/bash; plain "${ARGS[@]}" errors with
# 'unbound variable' when no cents args are passed.
"$CENTS_BIN" ${ARGS[@]+"${ARGS[@]}"} >>"$LOG_FILE" 2>&1
EXIT=$?

echo "[cents-wrap] $(date -Iseconds) end $CMD_NAME exit=$EXIT" >>"$LOG_FILE"
exit "$EXIT"
