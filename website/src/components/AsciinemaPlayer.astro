---
/**
 * AsciinemaPlayer
 *
 * Wraps the asciinema-player web component. Falls back to a "demo recording
 * coming soon" placeholder when the cast file is missing or empty.
 *
 * Loads the player JS + CSS lazily on the client. Server renders the
 * placeholder; the script swaps in the real player after mount if the cast
 * URL responds with a non-trivial body.
 */
interface Props {
  /** Path to the .cast file under /public (e.g. "/demo.cast"). */
  src: string;
  /** Optional poster, e.g. "npt:0:5". */
  poster?: string;
  /** Player rows. */
  rows?: number;
  /** Player cols. */
  cols?: number;
  /** Auto-play when ready. */
  autoplay?: boolean;
}

const {
  src,
  poster = "npt:0:1",
  rows = 24,
  cols = 100,
  autoplay = false,
} = Astro.props;

const playerId = `asciinema-${Math.random().toString(36).slice(2, 10)}`;
---

<div class="asciinema-wrapper">
  <div id={playerId} class="asciinema-mount">
    <div class="asciinema-placeholder">
      <p><strong>Demo recording coming soon.</strong></p>
      <p class="asciinema-placeholder__sub">
        The asciinema cast at <code>{src}</code> is a placeholder. Once recorded,
        it will play here in-browser.
      </p>
    </div>
  </div>
</div>

<script
  define:vars={{ src, poster, rows, cols, autoplay, playerId }}
  type="module"
>
  // The asciinema bundle is a UMD script (sets `window.AsciinemaPlayer`),
  // not an ES module — load it via a <script> tag, not import().
  // Vendored locally so the docs site has no third-party CDN dependency.
  const PLACEHOLDER_BYTES = 32;
  const PLAYER_CSS = "/vendor/asciinema-player/asciinema-player.css";
  const PLAYER_JS = "/vendor/asciinema-player/asciinema-player.min.js";

  // Cache promises on window so concurrent <AsciinemaPlayer> instances share
  // one load — otherwise a second mount() finds the <script> already in the
  // DOM, resolves injectOnce immediately, and races window.AsciinemaPlayer.
  const ASSETS_KEY = "__centsAsciinemaAssets";

  function loadAsset(selector, build) {
    const existing = document.querySelector(selector);
    if (existing) {
      // The element exists but may still be loading; we always promise-wrap.
      return new Promise((resolve, reject) => {
        if (existing.dataset.loaded === "1") return resolve();
        existing.addEventListener("load", () => resolve(), { once: true });
        existing.addEventListener("error", () => reject(new Error("asset load failed")), { once: true });
      });
    }
    return new Promise((resolve, reject) => {
      const el = build();
      el.addEventListener("load", () => { el.dataset.loaded = "1"; resolve(); }, { once: true });
      el.addEventListener("error", () => reject(new Error("asset load failed")), { once: true });
      document.head.appendChild(el);
    });
  }

  function loadPlayerAssets() {
    if (!window[ASSETS_KEY]) {
      window[ASSETS_KEY] = Promise.all([
        loadAsset(`link[href="${PLAYER_CSS}"]`, () => {
          const link = document.createElement("link");
          link.rel = "stylesheet";
          link.href = PLAYER_CSS;
          return link;
        }),
        loadAsset(`script[src="${PLAYER_JS}"]`, () => {
          const script = document.createElement("script");
          script.src = PLAYER_JS;
          script.async = true;
          return script;
        }),
      ]);
    }
    return window[ASSETS_KEY];
  }

  async function mount() {
    try {
      const head = await fetch(src, { method: "HEAD" });
      if (!head.ok) return;
      // Skip only when Content-Length is present AND tiny (placeholder). If
      // the header is missing entirely (unusual on static hosts), assume the
      // cast is real and let the player handle a malformed body itself.
      const lenHeader = head.headers.get("content-length");
      if (lenHeader !== null) {
        const len = Number(lenHeader);
        if (len > 0 && len < PLACEHOLDER_BYTES) return;
      }

      await loadPlayerAssets();
      if (!window.AsciinemaPlayer) return;
      const target = document.getElementById(playerId);
      if (!target) return;
      target.innerHTML = "";
      window.AsciinemaPlayer.create(src, target, { poster, rows, cols, autoplay });
    } catch {
      // Network or load error — leave the placeholder visible.
    }
  }
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", mount, { once: true });
  } else {
    mount();
  }
</script>

<style>
  .asciinema-wrapper {
    margin: 1.5rem 0;
    border-radius: 0.5rem;
    overflow: hidden;
    background: var(--sl-color-black);
  }
  .asciinema-placeholder {
    padding: 2rem 1.25rem;
    text-align: center;
    color: var(--sl-color-gray-3);
    font-family: var(--__sl-font-mono, monospace);
  }
  .asciinema-placeholder code {
    background: var(--sl-color-gray-6);
    padding: 0.1em 0.3em;
    border-radius: 3px;
  }
  .asciinema-placeholder__sub {
    font-size: 0.875rem;
    margin-top: 0.5rem;
  }
</style>
